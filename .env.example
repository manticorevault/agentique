SKILLSMP_API_KEY=sk_live_your_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
PORT=3001

# Optional — Telegram bot integration
# 1. Message @BotFather on Telegram and create a bot to get the token
# 2. Add the token below — long polling starts automatically on server boot
TELEGRAM_BOT_TOKEN=

# URL shown in Telegram links ("View full results on web")
# For local dev this is fine; for production set to your public domain
PUBLIC_URL=http://localhost:5173
